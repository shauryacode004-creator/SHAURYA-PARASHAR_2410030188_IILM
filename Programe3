class Solution:
    def threeWayPartition(self, arr, a, b):
        n = len(arr)
        
        low = 0
        mid = 0
        high = n - 1
        
        while mid <= high:
            
            # Case 1: element less than a
            if arr[mid] < a:
                arr[low], arr[mid] = arr[mid], arr[low]
                low += 1
                mid += 1
            
            # Case 2: element greater than b
            elif arr[mid] > b:
                arr[mid], arr[high] = arr[high], arr[mid]
                high -= 1
            
            # Case 3: element in range [a, b]
            else:
                mid += 1
        
        return arr
